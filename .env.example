# 必填：GLaDOS / Railgun Cookie
# 获取方式：登录 glados.space 或 railgun.info 签到页 -> F12 -> Network -> 刷新
# 找到请求头 Cookie，复制类似：
# koa:sess=xxxx; koa:sess.sig=yyyy
# 多账号用 & 连接
GLADOS_COOKIES=

# 可选：积分兑换策略 plan100 | plan200 | plan500(默认)
GLADOS_EXCHANGE_PLAN=plan500

# 可选：PushDeer 推送 key
PUSHDEER_SENDKEY=

# 可选：Webhook 通知（签到结果 POST 到该 URL）
# 支持：generic / feishu / dingtalk / wecom / discord，默认 auto（按 URL 自动识别）
NOTIFY_WEBHOOK_URL=
NOTIFY_WEBHOOK_TYPE=auto

# 可选：详细日志 true/false
GLADOS_VERBOSE=false
